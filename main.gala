extern fn abc();
extern fn printf(fmt: ^byte, ..any);

fn print(fmt: string) {
    printf(transmute(^byte)&fmt[0]);
    return;
}
extern fn malloc(size: int): rawptr;
extern fn memcpy(dest: rawptr, src: rawptr, size: int);

fn main(): int {
    s := "Hello, World!\n";
    buf := [1024]byte{};
    print(s);
    return 0;
}
